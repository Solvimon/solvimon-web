{
  "name": "@solvimon/sdk",
  "version": "0.1.0",
  "description": "Solvimon's Front-end SDK provides you with the building blocks to create a billing self serve experience",
  "private": true,
  "scripts": {
    "analyze": "vite-bundle-visualizer",
    "prebuild": "npm run build:css",
    "build": "vite build",
    "build-storybook": "storybook build",
    "build:css": "tailwindcss -i ./src/assets/index.css -o ./.sdk/tailwind.css",
    "dev": "npm run storybook",
    "lint": "npm run lint:ci -- --fix",
    "lint:ci": "eslint . --fix --ignore-path .eslintignore",
    "prestorybook": "npm run build:css",
    "storybook": "storybook dev -p 6006",
    "test:unit": "vitest",
    "type-check": "vue-tsc --noEmit -p tsconfig.json --composite false",
    "watch": "vite build --watch",
    "watch:css": "npm run build:css -- --watch"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./solvimon-add-payment-method-form": {
      "types": "./dist/SolvimonAddPaymentMethodForm.ce.d.ts",
      "import": "./dist/SolvimonAddPaymentMethodForm.es.js",
      "require": "./dist/SolvimonAddPaymentMethodForm.cjs.js"
    }
  },
  "dependencies": {
    "@adyen/adyen-web": "^6.5.0",
    "@solvimon/tailwind-config": "^1.0.0",
    "@solvimon/ui": "^1.0.0",
    "@stripe/stripe-js": "^2.4.0",
    "jwt-decode": "^4.0.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.2.0",
    "@solvimon/eslint-config": "^1.2.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/eslint-plugin": "1.1.20",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.20",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-no-relative-import-paths": "^1.5.2",
    "eslint-plugin-unused-imports": "^2.0.0",
    "eslint-plugin-vue": "^9.10.0",
    "eslint": "^8.38.0",
    "glob": "^11.0.1",
    "jsdom": "^26.0.0",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite-plugin-dts": "^3.7.0",
    "vite-plugin-vue-devtools": "^7.6.8",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  },
  "optionalDependencies": {
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@storybook/vue3": "^8.4.7",
    "@storybook/vue3-vite": "^8.4.7",
    "eslint-plugin-storybook": "^0.11.2",
    "storybook": "^8.4.7",
    "vite-bundle-visualizer": "^1.2.1"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
